#!/usr/bin/env bash
#
# Build a Minecraft mod in this monorepo.
#
# Usage:
#   build-mod <mod>
#
# Examples:
#   build-mod redstone-backport
#
set -euo pipefail

# Find tooling directory
tooling_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
minecraft_dir="$(cd -- "${tooling_dir}/.." && pwd)"
mods_dir="${minecraft_dir}/mods"

# Bootstrap environment
source "${tooling_dir}/env.sh"

usage() {
	cat <<EOF
Usage: build-mod <mod>

Arguments:
  mod    Mod folder name under ${mods_dir}

Examples:
  build-mod redstone-backport
EOF
}

if [[ $# -ne 1 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
	usage
	exit 1
fi

mod_name="$1"
mod_dir="${mods_dir}/${mod_name}"

if [[ ! -d "${mod_dir}" ]]; then
	echo "error: mod '${mod_name}' not found at ${mod_dir}" >&2
	exit 1
fi

if [[ ! -x "${mod_dir}/gradlew" ]]; then
	echo "error: ${mod_dir}/gradlew is missing or not executable" >&2
	exit 1
fi

echo "Building mod: ${mod_name}..."
exec "${mod_dir}/gradlew" -p "${mod_dir}" build
