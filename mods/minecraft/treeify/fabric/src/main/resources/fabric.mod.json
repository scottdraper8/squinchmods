{
	"schemaVersion": 1,
	"id": "${modId}",
	"version": "${modVersion}",
	"name": "${modName}",
	"description": "${modDescription}",
	"authors": [
		"${modAuthor}"
	],
	"contact": {
		"homepage": "${modGitHub}",
		"sources": "${modGitHub}",
		"issues": "${modGitHub}/issues",
		"discord": "${modDiscord}"
	},
	"license": "${modLicense}",
	"icon": "icon.png",
	"environment": "*",
	"entrypoints": {
	        "main": [
	                "com.squinchmods.treeify.fabric.TreeifyFabric"
	        ],
	        "client": [
	                "com.squinchmods.treeify.fabric.TreeifyFabricClient"
	        ],
	        "modmenu": [
	                "com.squinchmods.treeify.fabric.modcompat.ModMenuCompat"
	        ]
	},
	"mixins": [
	        "treeify-common.mixins.json",
	        "treeify-fabric.mixins.json"
	],
	"depends": {
	        "minecraft": ">=${minMinecraftVersion}",
	        "fabricloader": "*",
	        "fabric-api": "*",
	        "yet_another_config_lib_v3": ">=${yaclVersion}"
	},
	"recommends": {
	        "modmenu": ">=${modMenuVersion}"
	},
	"custom": {
	        "modmenu": {
	                "links": {
	                        "Discord": "${modDiscord}",
	                        "CurseForge": "https://www.curseforge.com/minecraft/mc-mods/treeify",
	                        "Modrinth": "https://modrinth.com/mod/treeify"
	                }
	        },
	        "catalogue": {
	                "configFactory": "com.squinchmods.treeify.fabric.modcompat.CatalogueCompat",			"icon": {
				"image": "icon.png"
			},
			"banner": "logo.png"
		},
		"mc-publish": {
			"dependencies": [
				"fabric-api(required){curseforge:306612}{modrinth:P7dR8mSH}",
				"yet_another_config_lib_v3(required){curseforge:667299}{modrinth:1eAoo2KR}",
				"modmenu(required){curseforge:308702}{modrinth:mOgUt4GM}"
			]
		}
	}
}