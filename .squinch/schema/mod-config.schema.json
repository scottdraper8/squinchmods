{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://squinchmods/.squinch/schema/mod-config.schema.json",
  "title": "squinchmods mod-level QA config",
  "description": "Per-mod targets/profiles/tests. See .agent-docs/games/minecraft/README.md. Lives centrally in squinchmods under .squinch/games/minecraft/mods/<mod>/config.yml, not inside the mod's own repo, so upstream-facing fork submodules never need squinchmods-specific files.",
  "type": "object",
  "required": ["schema", "mod", "targets"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": 1
    },
    "mod": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/target"
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/profileOverride"
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/testDef"
      }
    },
    "expected_failures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/expectedFailure"
      }
    }
  },
  "$defs": {
    "target": {
      "type": "object",
      "required": ["id", "minecraft", "loader", "java", "capabilities"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "minecraft": { "type": "string", "minLength": 1 },
        "loader": {
          "type": "string",
          "enum": ["forge", "neoforge", "fabric", "quilt"]
        },
        "loader_version": { "type": "string" },
        "java": { "type": "integer", "minimum": 8 },
        "supported": { "type": "boolean", "default": true },
        "capabilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "profileOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "extends": { "type": "string" },
        "add": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean", "default": true },
              "config": {
                "type": "object",
                "description": "Profile-specific test configuration override; shallow-merged over parent and mod test defaults."
              }
            }
          }
        }
      }
    },
    "testDef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requires": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "adapters": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "minLength": 1 }
            }
          }
        },
        "config": {
          "type": "object",
          "description": "Test-specific configuration, shape depends on the test."
        },
        "expectations": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "default": { "type": "object" },
            "by_target": {
              "type": "object",
              "additionalProperties": { "type": "object" }
            }
          }
        }
      }
    },
    "expectedFailure": {
      "type": "object",
      "required": ["target", "test", "reason"],
      "additionalProperties": false,
      "properties": {
        "target": { "type": "string", "minLength": 1 },
        "test": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "expires": {
          "type": "string",
          "format": "date"
        }
      }
    }
  }
}
